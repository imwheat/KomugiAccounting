<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.KomugiAccounting" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.KomugiAccounting.Starting" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.KomugiAccounting.Picker" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:colorAccent">#6650A4</item>
        <item name="android:colorControlActivated">#6650A4</item>
        <item name="android:colorControlHighlight">#D0BCFF</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#6650A4</item>
    </style>

    <style name="Theme.KomugiAccounting.Picker.Dark" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:colorAccent">#D0BCFF</item>
        <item name="android:colorControlActivated">#D0BCFF</item>
        <item name="android:colorControlHighlight">#6650A4</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#FFFFFF</item>
    </style>
</resources>
